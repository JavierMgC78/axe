# ══════════════════════════════════════════════════════════════════════════════
#  AXE ROUTER — public/.htaccess
#  Reescritura de URLs para el patrón Front Controller
# ══════════════════════════════════════════════════════════════════════════════
#
#  Objetivo: redirigir TODA petición que no corresponda a un archivo o
#  directorio físico hacia public/index.php, que actúa como único punto
#  de entrada de la aplicación.
#
#  Requisito: mod_rewrite habilitado en Apache (activo por defecto en XAMPP).
# ══════════════════════════════════════════════════════════════════════════════

# ── 1. Activar el motor de reescritura ────────────────────────────────────────
Options -Indexes
RewriteEngine On

# ── 2. Condiciones de excepción ───────────────────────────────────────────────
# Si la URL apunta a un ARCHIVO físico que existe → no reescribir.
# (p. ej. /css/app.css, /images/logo.png, /favicon.ico)
RewriteCond %{REQUEST_FILENAME} !-f

# Si la URL apunta a un DIRECTORIO físico que existe → no reescribir.
# (p. ej. /uploads/, si alguna vez existiera como carpeta pública)
RewriteCond %{REQUEST_FILENAME} !-d

# ── 3. Regla de captura universal ─────────────────────────────────────────────
# Cualquier ruta que supere las condiciones anteriores es enviada a index.php.
#   QSA  → Query String Append: preserva los parámetros ?foo=bar originales.
#   L    → Last: detiene el procesamiento de reglas adicionales.
RewriteRule ^ index.php [QSA,L]
